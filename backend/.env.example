# Required - server will refuse to start without these
# ADMIN_PASSWORD: use a strong random value (min 20 chars), e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Never commit the real value to git.
ADMIN_PASSWORD=REPLACE_WITH_A_STRONG_RANDOM_PASSWORD_MIN_20_CHARS
# JWT_SECRET: min 32 random chars, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=REPLACE_WITH_A_RANDOM_STRING_MIN_32_CHARS

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/duelo

# CORS - comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# AI generation (La Forge feature) — https://console.anthropic.com
ANTHROPIC_API_KEY=
